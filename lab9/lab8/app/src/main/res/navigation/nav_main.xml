<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_main"
    app:startDestination="@id/mainFragment">

    <fragment
        android:id="@+id/mainFragment"
        android:name="com.example.lab8.MainFragment"
        android:label="fragment_main"
        tools:layout="@layout/fragment_main" >
        <action
            android:id="@+id/action_mainFragment_to_secondActivity"
            app:destination="@id/secondActivity" />
        <action
            android:id="@+id/action_mainFragment_to_fragment_third"
            app:destination="@id/fragment_third" />
        <action
            android:id="@+id/action_mainFragment_to_fragment_second"
            app:destination="@id/fragment_second" />
    </fragment>
    <activity
        android:id="@+id/secondActivity"
        android:name="com.example.lab8.SecondActivity"
        android:label="activity_second"
        tools:layout="@layout/activity_second" />
    <fragment
        android:id="@+id/fragment_second"
        android:name="com.example.lab8.fragment_second"
        android:label="fragment_second"
        tools:layout="@layout/fragment_second" >
        <action
            android:id="@+id/action_fragment_second_to_mainFragment"
            app:destination="@id/mainFragment" />
    </fragment>
    <fragment
        android:id="@+id/fragment_third"
        android:name="com.example.lab8.fragment_third"
        android:label="fragment_third"
        tools:layout="@layout/fragment_third" >
        <action
            android:id="@+id/action_fragment_third_to_mainFragment"
            app:destination="@id/mainFragment" />
    </fragment>
</navigation>