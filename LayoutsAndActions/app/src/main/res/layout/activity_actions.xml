<?xml version="1.0" encoding="utf-8"?>
<layout>
    <data>
        <variable
            name="user"
            type="com.example.layoutsandactions.User" />
    </data>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main4">

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="@string/write_to_logcat"
        android:textSize="30sp"
        android:onClick="writeToLogCat"
        />

    <Button
        android:id="@+id/btn_write_to_logcat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="@string/write_to_logcat_listener"
        android:textSize="30sp"
        />

    <Button
        android:id="@+id/btn_show_toast"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="@string/toast"
        android:textSize="30sp"
        />

    <TextView
        android:id="@+id/tv_write_something"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:textSize="30sp"
        android:textAlignment="center"
        android:text='@{user.firstName + " " + user.lastName}'

        />

    <Button
        android:id="@+id/btn_write_to_textview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="@string/write_textview"
        android:textSize="30sp"
        />

    <EditText
        android:id="@+id/et_first_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="30sp"
        android:layout_marginTop="30dp"
        android:textAlignment="center"
        android:hint="Name"
        android:text="@={user.firstName}"
        />

    <EditText
        android:id="@+id/et_last_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="30sp"
        android:layout_marginTop="30dp"
        android:textAlignment="center"
        android:hint="Surname"
        android:text="@={user.lastName}"
        />

    <Button
        android:id="@+id/btn_write_user"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="@string/update_user"
        android:textSize="30sp"
        android:onClick="setUpdateUserDataButtonListener"
        />
</LinearLayout>
</layout>